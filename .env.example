# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Dev:  sqlite:///db.sqlite3       (default if unset)
# Prod: postgres://USER:PASSWORD@postgres:5432/DBNAME
DATABASE_URL=sqlite:///db.sqlite3

# --- Prod only (.env.prod on the prod host) ---
# Required by docker-compose.prod.yml — POSTGRES_PASSWORD is mandatory.
# POSTGRES_DB=raffledb
# POSTGRES_USER=raffleuser
# POSTGRES_PASSWORD=generate-with-openssl-rand-hex-24
# CSRF_TRUSTED_ORIGINS=https://your.domain.example
